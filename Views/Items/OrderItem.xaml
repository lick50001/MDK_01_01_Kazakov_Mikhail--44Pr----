<UserControl x:Class="Postavki.Views.Items.OrderItem"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             mc:Ignorable="d"
             FontFamily="Bahnschrift Light Condensed">
    <UserControl.Resources>
        <Style TargetType="Button" x:Key="Update">
            <Setter Property="Background" Value="#FF2DD61B"/>
            <Setter Property="BorderBrush" Value="#FF2DD61B"/>
            <Setter Property="Foreground" Value="White"/>
        </Style>
        <Style TargetType="Button" x:Key="Delete">
            <Setter Property="Background" Value="#FFD62F1B"/>
            <Setter Property="BorderBrush" Value="#FFD62F1B"/>
            <Setter Property="Foreground" Value="White"/>
        </Style>
    </UserControl.Resources>
    <Grid Margin="10" Background="White">
        <Grid.Effect>
            <DropShadowEffect Opacity="0.1"/>
        </Grid.Effect>
        <Grid Margin="60, 0, 0, 0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="270"/>
            </Grid.ColumnDefinitions>

            <Grid Margin="10" Height="60" VerticalAlignment="Top" Background="White">
                <Grid.Effect>
                    <DropShadowEffect Opacity="0.1"/>
                </Grid.Effect>
                <Label Content="Наименование:" VerticalAlignment="Top" Margin="10, 0, 10, 0"/>
                <TextBox Text="{Binding Name}"
                         IsEnabled="{Binding IsEnable}"
                         VerticalContentAlignment="Center"
                         Margin="10, 25, 10, 0"
                         VerticalAlignment="Top"
                         Height="25"/>
            </Grid>

            <Grid Margin="10, 80, 10, 0" Height="60" VerticalAlignment="Top" Background="White">
                <Grid.Effect>
                    <DropShadowEffect Opacity="0.1"/>
                </Grid.Effect>
                <Label Content="Приоритет:" VerticalAlignment="Top" Margin="10, 0, 10, 0"/>
                <TextBox Text="{Binding Priority}"
                         IsEnabled="{Binding IsEnable}"
                         VerticalContentAlignment="Center"
                         Margin="10, 25, 10, 0"
                         VerticalAlignment="Top"
                         Height="25"/>
            </Grid>

            <Grid Margin="10,10,10,0" Height="60" VerticalAlignment="Top" Background="White" Grid.Column="1">
                <Grid.Effect>
                    <DropShadowEffect Opacity="0.1"/>
                </Grid.Effect>
                <Label Content="Срок выполнения:" VerticalAlignment="Top" Margin="10, 0, 10, 0"/>
                <DatePicker SelectedDate="{Binding DateTime}"
                            IsEnabled="{Binding IsEnable}"
                            Margin="10, 25, 10, 0"
                            VerticalAlignment="Top"
                            Height="25"/>
            </Grid>

            <Grid Margin="10,80,10,0" Height="60" VerticalAlignment="Top" Background="White" Grid.Column="1">
                <Grid.Effect>
                    <DropShadowEffect Opacity="0.1"/>
                </Grid.Effect>
                <Label Content="Комментарий:" VerticalAlignment="Top" Margin="10, 0, 10, 0"/>
                <TextBox Text="{Binding Description}"
                         IsEnabled="{Binding IsEnable}"
                         VerticalContentAlignment="Center"
                         Margin="10, 25, 10, 0"
                         VerticalAlignment="Top"
                         Height="25"/>
            </Grid>

            <Grid Margin="10,150,10,0" Height="60" VerticalAlignment="Top" Background="White" Grid.Column="1">
                <Grid.Effect>
                    <DropShadowEffect Opacity="0.1"/>
                </Grid.Effect>
                <Label Content="Поставщик:" VerticalAlignment="Top" Margin="10, 0, 10, 0"/>
                <ComboBox ItemsSource="{Binding DataContext.AllSuppliers, RelativeSource={RelativeSource AncestorType=Page}}"
                          SelectedItem="{Binding Supplier}"
                          DisplayMemberPath="Name"
                          IsEnabled="{Binding IsEnable}"
                          Margin="10, 25, 10, 0"
                          VerticalAlignment="Top"
                          Height="25"/>
            </Grid>
        </Grid>

        <!-- Кнопка "Изменить / Сохранить" -->
        <Button Style="{StaticResource Update}"
        Command="{Binding DataContext.OnToggleEditOrder, RelativeSource={RelativeSource AncestorType=Page}}"
        CommandParameter="{Binding}"
        Content="{Binding IsEnableText}"
        Height="25" Width="70"
        VerticalAlignment="Top" HorizontalAlignment="Right" Margin="0,175,281,0">
            <Button.Effect>
                <DropShadowEffect Opacity="0.5" BlurRadius="3" ShadowDepth="3"/>
            </Button.Effect>
        </Button>

        <!-- Кнопка "Удалить" — ВСЕГДА активна -->
        <Button Style="{StaticResource Delete}"
        Command="{Binding DataContext.OnDeleteOrder, RelativeSource={RelativeSource AncestorType=Page}}"
        CommandParameter="{Binding}"
        Content="Удалить"
        Height="25" Width="70"
        VerticalAlignment="Top" HorizontalAlignment="Right" Margin="0,175,356,0">
            <Button.Effect>
                <DropShadowEffect Opacity="0.5" BlurRadius="3" ShadowDepth="3"/>
            </Button.Effect>
        </Button>
    </Grid>
</UserControl>
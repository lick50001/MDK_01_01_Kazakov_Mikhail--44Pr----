<Page x:Class="Postavki.Views.Main"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:suppliers="clr-namespace:Postavki.Views.Items"
      xmlns:orders="clr-namespace:Postavki.Views.Items"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="Управление складом"
      FontFamily="Bahnschrift Light Condensed">

    <Grid Background="#F8F9FA">
        <TabControl Margin="10">
            <!-- Вкладка: Поставщики -->
            <TabItem Header="Поставщики">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                        <Button Content="Добавить поставщика" 
                                Width="150" Height="30"
                                Command="{Binding OnAddSupplier}"
                                Background="#FF2DD61B" Foreground="White" BorderBrush="#FF2DD61B"/>
                    </StackPanel>

                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding Suppliers}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <suppliers:SupplierItem Margin="0,0,0,10"/>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </TabItem>

            <TabItem Header="Заказы">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                        <Button Content="Создать заказ" 
                                Width="150" Height="30"
                                Command="{Binding OnAddOrder}"
                                Background="#FF2DD61B" Foreground="White" BorderBrush="#FF2DD61B"/>
                    </StackPanel>

                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding Orders}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <orders:OrderItem Margin="0,0,0,10"/>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </TabItem>
        </TabControl>
    </Grid>
</Page>